+            "prim_generic_flop.sv"
         )
 
         rtl_base = os.path.join(ibexdir, "rtl")
@@ -262,7 +263,30 @@ class Ibex(CPU):
             "ibex_csr.sv",
             "ibex_top.sv"
             )
-        platform.add_source(os.path.join(ibexdir, "dv", "uvm", "core_ibex", "common", "prim", "prim_buf.sv"))
+        # Build under the yosys-slang SystemVerilog frontend (see
+        # litex/build/yosys_wrapper.py). read_verilog -sv cannot parse these
+        # lowRISC sources, so slang is always required; being a full elaborator
+        # it also needs the prim sources it would otherwise miss.
+        platform.use_slang = True
+        platform.add_sources(os.path.join(ibexdir, "dv", "uvm", "core_ibex", "common", "prim"),
+            "prim_buf.sv",
+            "prim_flop.sv"
+        )
+
+        # Register file selection. The flip-flop file (ibex_register_file_ff.sv,
+        # pulled in via ibex_core.f) is Ibex's portable default and maps on any
+        # fabric. A board tight on LUTs can opt into the distributed-RAM file by
+        # setting platform.ibex_regfile = "fpga" in its target; on a GW1NR-9 that
+        # drops the SoC from an overflowing 106% (9211/8640 LUT4) to ~80%.
+        # Distributed RAM is not universal (e.g. iCE40 has none), so it stays
+        # opt-in rather than the default.
+        regfiles = {"ff": 0, "fpga": 1}
+        regfile  = getattr(platform, "ibex_regfile", "ff")
+        if regfile not in regfiles:
+            raise ValueError(f"Ibex: unknown ibex_regfile {regfile!r}, expected one of {list(regfiles)}.")
+        if regfile == "fpga":
+            platform.add_source(os.path.join(rtl_base, "ibex_register_file_fpga.sv"))
+        platform.slang_extra = f"--relax-enum-conversions --ignore-initial --top ibex_top -G RegFile={regfiles[regfile]}"
