diff --git a/litex/build/yosys_wrapper.py b/litex/build/yosys_wrapper.py
index e8ccb38cd..8f8f8b615 100644
--- a/litex/build/yosys_wrapper.py
+++ b/litex/build/yosys_wrapper.py
@@ -76,15 +76,32 @@ class YosysWrapper():
         """
         includes = ""
         reads = []
+        sv_files = []
+        # Opt-in: route SystemVerilog through the yosys-slang plugin instead of
+        # the built-in read_verilog -sv frontend. Off by default, so existing
+        # builds are byte-for-byte unchanged and never require the plugin. A core
+        # sets platform.use_slang = True when its SystemVerilog needs a full
+        # elaborator that read_verilog -sv cannot parse (e.g. lowRISC Ibex).
         for path in self._platform.verilog_include_paths:
             includes += " -I" + path
         for filename, language, library, *copy in self._platform.sources:
             # yosys has no such function read_systemverilog
             if language == "systemverilog":
+                if getattr(self._platform, "use_slang", False):
+                    sv_files.append(filename)
+                    continue
                 language = "verilog -sv"
             if language is None:
                 continue
             reads.append(f'read_{language}{includes} "{filename}"')
+        if sv_files:
+            files = " ".join(sv_files)
+            # Per-design slang options (e.g. a top-level parameter override or
+            # --ignore-initial); set by the enabling core, empty otherwise.
+            extra = getattr(self._platform, "slang_extra", "")
+            extra = f" {extra}" if extra else ""
+            reads.insert(0, "plugin -i slang")
+            reads.append(f"read_slang --ignore-unknown-modules{extra}{includes} {files}")
         return "\n".join(reads)

     _default_template = [
