# Tang Nano 9K (onboard FT2232, 0403:6010) permissions.
#
# The stock 70-openfpgaloader.rules grants access with MODE="664" plus a
# uaccess ACL for the logged-in user. That is enough for host-side tools, but
# `make flash`/`make run` reach the board from inside a rootless Podman
# container, where the container process maps to an unprivileged host uid that
# is outside the device's user namespace. The owner, plugdev group, and uaccess
# ACL all render as nobody/nogroup inside the container, so the process falls
# through to the "other" permission bits. libftdi needs write access to open the
# device, so read-only "other" bits make openFPGALoader fail with
# `usb_open() failed: -4`.
#
# MODE="0666" gives "other" read+write, which is what the in-namespace process
# sees. This runs after 70- (the 99- prefix sorts later), so its MODE wins.
ACTION!="add|change", GOTO="tangnano9k_rules_end"
SUBSYSTEM!="usb|tty", GOTO="tangnano9k_rules_end"
ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6010", MODE="0666"
LABEL="tangnano9k_rules_end"
